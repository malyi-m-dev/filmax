# Шаблон локальных секретов подписи release.
# Скопируй в keystore.properties (он в .gitignore) и подставь свои значения.
#
# storeFile   — путь к release-keystore (.jks). Держи его ВНЕ репозитория.
# storePassword / keyPassword — пароли keystore и ключа.
# keyAlias    — алиас ключа внутри keystore.
#
# В CI эти же значения берутся из GitHub Secrets (env):
#   KEYSTORE_FILE / KEYSTORE_PASSWORD / KEY_ALIAS / KEY_PASSWORD
# (сам keystore в CI декодируется из секрета KEYSTORE_BASE64).

storeFile=C:/path/to/filmax-release.jks
storePassword=CHANGE_ME
keyAlias=filmax
keyPassword=CHANGE_ME
